@model LifeQuest.BLL.DTOs.DecisionDTO
@{
    ViewData["Title"] = "Delete Decision";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 text-center">
            <div class="card border-0 shadow-lg rounded-4 p-5">
                <div class="text-danger mb-4">
                    <i class="fas fa-exclamation-triangle fa-5x"></i>
                </div>
                <h3 class="fw-bold mb-3">Delete this record?</h3>
                <p class="text-muted mb-5">
                    Are you sure you want to delete <strong>"@Model.Name"</strong>? 
                    This will also remove all associated performance metrics.
                </p>

                <form asp-action="DeleteConfirmed" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-danger btn-lg rounded-pill shadow">
                            <i class="fas fa-trash-alt me-2"></i> Confirm Delete
                        </button>
                        <a asp-action="Index" class="btn btn-link text-muted mt-2">No, Keep it</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
