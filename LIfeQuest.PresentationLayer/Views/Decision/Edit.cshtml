@model LifeQuest.BLL.DTOs.DecisionDTO
@{
    ViewData["Title"] = "Update Result";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-white p-4 border-0 text-center">
                    <div class="stats-icon bg-warning bg-opacity-10 text-warning mb-3 mx-auto">
                        <i class="fas fa-poll-h fa-2x"></i>
                    </div>
                    <h4 class="fw-bold mb-0">What was the outcome?</h4>
                    <p class="text-muted small mt-2">@Model.Name</p>
                </div>
                <div class="card-body p-4 p-md-5 text-center">
                    <form asp-action="Edit" method="post">
                        <input type="hidden" name="id" value="@Model.Id" />
                        
                        <div class="d-grid gap-3 mb-4">
                            <button type="submit" name="isSuccess" value="true" class="btn btn-success btn-lg rounded-pill shadow-sm py-3">
                                <i class="fas fa-check-circle me-2"></i> IT WAS A SUCCESS
                            </button>
                            <button type="submit" name="isSuccess" value="false" class="btn btn-danger btn-lg rounded-pill shadow-sm py-3">
                                <i class="fas fa-times-circle me-2"></i> IT FAILED / NOT OPTIMAL
                            </button>
                        </div>

                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-link text-muted mt-3">I'm not ready to judge yet</a>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .stats-icon {
        width: 70px;
        height: 70px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
    }
</style>
