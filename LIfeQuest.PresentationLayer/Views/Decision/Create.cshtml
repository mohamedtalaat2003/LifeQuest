@model LifeQuest.BLL.DTOs.DecisionDTO
@{
    ViewData["Title"] = "Record Decision";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="card-header bg-primary text-white p-4 border-0">
                    <h4 class="fw-bold mb-0"><i class="fas fa-balance-scale me-2"></i> Record New Decision</h4>
                </div>
                <div class="card-body p-4 p-md-5">
                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="Name" class="form-label fw-bold">What is the decision?</label>
                            <input asp-for="Name" class="form-control form-control-lg rounded-3 shadow-sm" placeholder="e.g., Accepting the new job offer" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-6">
                                <label asp-for="RiskLevel" class="form-label fw-bold">Risk Level</label>
                                <select asp-for="RiskLevel" class="form-select rounded-3 shadow-sm">
                                    <option value="Easy">Easy / Low Risk</option>
                                    <option value="Medium" selected>Medium Risk</option>
                                    <option value="Hard">Hard / High Risk</option>
                                </select>
                                <span asp-validation-for="RiskLevel" class="text-danger small"></span>
                            </div>
                            <div class="col-md-6 d-flex align-items-end">
                                <div class="form-check form-switch mb-2">
                                    <input asp-for="IsConfident" class="form-check-input" type="checkbox" id="flexSwitchCheckDefault">
                                    <label class="form-check-label fw-bold" for="flexSwitchCheckDefault">Are you confident?</label>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-5">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill shadow">
                                <i class="fas fa-save me-2"></i> Save Decision
                            </button>
                            <a asp-action="Index" class="btn btn-link text-muted mt-2">Cancel and Go Back</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
