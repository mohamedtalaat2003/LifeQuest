@model IEnumerable<LifeQuest.BLL.DTOs.DecisionDTO>
@{
    ViewData["Title"] = "Decision Lab";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="fw-bold mb-2">Decision Lab</h1>
            <p class="text-muted">Analyze your choices and improve your judgment over time.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 py-2 shadow">
            <i class="fas fa-plus me-2"></i> New Decision
        </a>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var decision in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden card-hover">
                        <div class="card-body p-4">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <span class="badge @(decision.RiskLevel == "Hard" ? "bg-danger" : decision.RiskLevel == "Medium" ? "bg-warning" : "bg-success") rounded-pill px-3">
                                    @decision.RiskLevel Risk
                                </span>
                                @if (decision.IsConfident)
                                {
                                    <span class="text-primary" title="Confident in this decision">
                                        <i class="fas fa-bolt"></i>
                                    </span>
                                }
                            </div>
                            
                            <h5 class="fw-bold mb-3">@decision.Name</h5>
                            
                            <div class="row g-2 mb-4">
                                <div class="col-6">
                                    <div class="bg-light rounded-3 p-2 text-center">
                                        <div class="small text-muted mb-1">Success Rate</div>
                                        <div class="fw-bold text-dark">@(decision.Metrics?.SuccessRate ?? 0)%</div>
                                    </div>
                                </div>
                                <div class="col-6">
                                    <div class="bg-light rounded-3 p-2 text-center">
                                        <div class="small text-muted mb-1">Confidence</div>
                                        <div class="fw-bold text-dark">@(decision.Metrics?.ConfidenceAccuracy ?? 0)%</div>
                                    </div>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mt-auto">
                                <a asp-action="Details" asp-route-id="@decision.Id" class="btn btn-outline-primary btn-sm rounded-pill px-3">
                                    View Analytics
                                </a>
                                <div class="dropdown">
                                    <button class="btn btn-link btn-sm text-muted" type="button" data-bs-toggle="dropdown">
                                        <i class="fas fa-ellipsis-v"></i>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow border-0 rounded-3">
                                        <li><a class="dropdown-item" asp-action="Edit" asp-route-id="@decision.Id">Update Result</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item text-danger" asp-action="Delete" asp-route-id="@decision.Id">Delete</a></li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="opacity-25 mb-4">
                    <i class="fas fa-balance-scale fa-5x"></i>
                </div>
                <h3>No decisions recorded yet.</h3>
                <p class="text-muted">Start tracking your big choices to see patterns in your success.</p>
                <a asp-action="Create" class="btn btn-primary mt-3">Record Your First Decision</a>
            </div>
        }
    </div>
</div>

<style>
    .card-hover { transition: all 0.3s ease; }
    .card-hover:hover { transform: translateY(-10px); }
    .card { border-top: 4px solid #4e73df !important; }
</style>
