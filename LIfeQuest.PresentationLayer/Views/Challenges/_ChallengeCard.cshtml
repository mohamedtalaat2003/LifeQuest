@model LifeQuest.PresentationLayer.ViewModels.Challenges.ChallengeViewModel
@using LifeQuest.DAL.Models

<div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden position-relative">
    @{
        var borderClass = Model.Difficulty == ChallengeDifficulty.Hard ? "bg-danger" : Model.Difficulty == ChallengeDifficulty.Medium ? "bg-warning" : "bg-success";
        var textClass = Model.Difficulty == ChallengeDifficulty.Hard ? "text-danger" : Model.Difficulty == ChallengeDifficulty.Medium ? "text-warning" : "text-success";
    }
    <div style="height: 4px;" class="@borderClass opacity-75"></div>
    
    <div class="card-body p-4 d-flex flex-column">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="badge @borderClass bg-opacity-10 @textClass px-3 py-2 rounded-pill border border-@textClass border-opacity-10 small fw-bold text-uppercase" style="letter-spacing: 0.5px;">
                @Model.Difficulty
            </span>
            <span class="points-indicator fw-bold small"><i class="fas fa-coins me-1"></i> @Model.Points pts</span>
        </div>
        
        <h5 class="fw-bold mb-2 text-dark">@Model.Title</h5>
        <div class="text-secondary small mb-4 text-truncate-2" style="height: 3rem; overflow: hidden;">
            @Model.Description
        </div>
        
        <div class="mt-auto">
            <div class="d-flex justify-content-between mb-2 small text-muted">
                <span><i class="fas fa-calendar-day me-1 opacity-50"></i> @Model.Duration Days</span>
                <span>@Model.StartDate.ToString("MMM dd") - @Model.EndDate.ToString("MMM dd")</span>
            </div>
            
            <div class="progress mb-4 rounded-pill" style="height: 6px;">
                <div class="progress-bar rounded-pill @borderClass" style="width: 100%"></div>
            </div>
            
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm w-100 rounded-pill fw-bold py-2 shadow-sm">
                Launch Quest <i class="fas fa-chevron-right ms-2 small"></i>
            </a>
        </div>
    </div>
</div>

