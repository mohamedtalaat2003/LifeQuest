@model LifeQuest.PresentationLayer.ViewModels.Challenges.ChallengeViewModel
@using LifeQuest.DAL.Models

<div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden card-hover position-relative">
    @{
        var borderClass = Model.Difficulty == ChallengeDifficulty.Hard ? "bg-danger" : Model.Difficulty == ChallengeDifficulty.Medium ? "bg-warning" : "bg-success";
    }
    <div style="height: 4px;" class="@borderClass"></div>
    
    <div class="card-body p-4">
        <div class="d-flex justify-content-between align-items-start mb-3">
            <span class="badge @(Model.Difficulty == ChallengeDifficulty.Hard ? "bg-danger" : Model.Difficulty == ChallengeDifficulty.Medium ? "bg-warning" : "bg-success") bg-opacity-10 text-@(Model.Difficulty == ChallengeDifficulty.Hard ? "danger" : Model.Difficulty == ChallengeDifficulty.Medium ? "warning" : "success") px-3 rounded-pill border small fw-bold">
                @Model.Difficulty
            </span>
            <span class="text-warning fw-bold small"><i class="fas fa-coins me-1"></i> @Model.Points pts</span>
        </div>
        
        <h5 class="fw-bold mb-2">@Model.Title</h5>
        <div class="text-muted small mb-4 text-truncate-2" style="height: 2.5rem; overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;">
            @Model.Description
        </div>
        
        <div class="mt-auto">
            <div class="d-flex justify-content-between mb-2 small">
                <span class="text-muted"><i class="fas fa-calendar-day me-1"></i> @Model.Duration Days</span>
                <span class="text-muted">@Model.StartDate.ToString("MMM dd") - @Model.EndDate.ToString("MMM dd")</span>
            </div>
            
            <div class="progress mb-4 rounded-pill" style="height: 6px; background-color: #f0f0f0;">
                <div class="progress-bar rounded-pill @borderClass" style="width: 100%"></div>
            </div>
            
            <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-primary btn-sm w-100 rounded-pill fw-bold py-2">
                Launch Quest <i class="fas fa-chevron-right ms-1"></i>
            </a>
        </div>
    </div>
</div>

<style>
    .card-hover { transition: all 0.3s cubic-bezier(.25,.8,.25,1); }
    .card-hover:hover { transform: translateY(-5px); box-shadow: 0 10px 25px rgba(0,0,0,0.08) !important; }
    .text-truncate-2 { display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
</style>
