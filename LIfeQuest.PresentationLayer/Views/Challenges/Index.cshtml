@model IEnumerable<LifeQuest.PresentationLayer.ViewModels.Challenges.ChallengeViewModel>
@using LifeQuest.DAL.Models
@{
    ViewData["Title"] = "Quest Board";
    var publicChallenges = Model.Where(c => c.IsPublic).ToList();
    var privateChallenges = Model.Where(c => !c.IsPublic).ToList();
}

<div class="container py-4">
    <div class="d-sm-flex align-items-center justify-content-between mb-5">
        <div>
            <h1 class="fw-bold text-dark mb-1">Quest Board</h1>
            <p class="text-secondary fs-5">Discover new challenges or track your personal progress.</p>
        </div>
        <div class="d-flex gap-2">
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" asp-route-isPublic="true" class="btn btn-success rounded-pill px-4 py-2 shadow-sm fw-bold">
                    <i class="fas fa-globe me-2"></i> Create Global Quest
                </a>
            }
            <a asp-action="Create" class="btn btn-primary rounded-pill px-4 py-2 shadow-sm fw-bold">
                <i class="fas fa-plus me-2"></i> Create Personal Quest
            </a>
        </div>
    </div>

    <!-- Custom Styled Tabs -->
    <ul class="nav nav-pills mb-5 quest-tabs d-inline-flex border-0" id="pills-tab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active px-4 py-2" id="pills-public-tab" data-bs-toggle="pill" data-bs-target="#pills-public" type="button" role="tab">
                <i class="fas fa-globe me-2"></i> Global Quests
                <span class="badge bg-primary bg-opacity-10 text-primary ms-2 border border-primary border-opacity-10">@publicChallenges.Count</span>
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link px-4 py-2" id="pills-private-tab" data-bs-toggle="pill" data-bs-target="#pills-private" type="button" role="tab">
                <i class="fas fa-lock me-2"></i> Personal Quests
                <span class="badge bg-secondary bg-opacity-10 text-secondary ms-2 border border-secondary border-opacity-10">@privateChallenges.Count</span>
            </button>
        </li>
    </ul>

    <div class="tab-content" id="pills-tabContent">
        <!-- Global Challenges Tab -->
        <div class="tab-pane fade show active" id="pills-public" role="tabpanel">
            <div class="row g-4">
                @if (!publicChallenges.Any())
                {
                    <div class="col-12 text-center py-5">
                        <div class="opacity-25 mb-3"><i class="fas fa-earth-americas fa-4x text-primary"></i></div>
                        <h4 class="text-secondary fw-bold">No global challenges found.</h4>
                        <p class="text-muted">Be the first to create a public quest for the community!</p>
                    </div>
                }
                else
                {
                    @foreach (var challenge in publicChallenges)
                    {
                        <div class="col-xl-4 col-md-6">
                            @await Html.PartialAsync("_ChallengeCard", challenge)
                        </div>
                    }
                }
            </div>
        </div>

        <!-- Personal Challenges Tab -->
        <div class="tab-pane fade" id="pills-private" role="tabpanel">
            <div class="row g-4">
                @if (!privateChallenges.Any())
                {
                    <div class="col-12 text-center py-5">
                        <div class="opacity-25 mb-3"><i class="fas fa-user-shield fa-4x text-secondary"></i></div>
                        <h4 class="text-secondary fw-bold">No personal quests yet.</h4>
                        <p class="text-muted">Create a private challenge to track your individual goals.</p>
                        <a asp-action="Create" class="btn btn-outline-primary rounded-pill mt-3">Start a Private Quest</a>
                    </div>
                }
                else
                {
                    @foreach (var challenge in privateChallenges)
                    {
                        <div class="col-xl-4 col-md-6">
                            @await Html.PartialAsync("_ChallengeCard", challenge)
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

