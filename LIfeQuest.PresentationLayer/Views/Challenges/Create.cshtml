@model LifeQuest.PresentationLayer.ViewModels.Challenges.CreateChallengeViewModel
@{
    ViewData["Title"] = "Create Challenge";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-lg border-0 rounded-4 overflow-hidden">
            <div class="card-header bg-dark text-white p-4">
                <h4 class="mb-0 fw-bold"><i class="fas fa-mountain-sun me-3 text-primary"></i> Forge New Challenge</h4>
                <p class="text-muted small mb-0 mt-1">Design a quest for yourself or the community.</p>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create" method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="mb-3">
                        <label asp-for="Title" class="form-label fw-bold"></label>
                        <input asp-for="Title" class="form-control form-control-lg" placeholder="e.g. 30 Days of .NET" />
                        <span asp-validation-for="Title" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-bold"></label>
                        <textarea asp-for="Description" class="form-control" rows="3" placeholder="What is this challenge about?"></textarea>
                        <span asp-validation-for="Description" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="StartDate" class="form-label fw-bold"></label>
                            <input asp-for="StartDate" class="form-control" />
                            <span asp-validation-for="StartDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="EndDate" class="form-label fw-bold"></label>
                            <input asp-for="EndDate" class="form-control" />
                            <span asp-validation-for="EndDate" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label asp-for="Difficulty" class="form-label fw-bold"><i class="fas fa-signal me-1 text-primary"></i> Difficulty</label>
                            <select asp-for="Difficulty" class="form-select form-select-lg rounded-3 shadow-sm border-0 bg-light">
                                <option value="Easy">Easy (50 pts)</option>
                                <option value="Medium" selected>Medium (100 pts)</option>
                                <option value="Hard">Hard (200 pts)</option>
                            </select>
                            <span asp-validation-for="Difficulty" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-4 d-flex align-items-center">
                            <div class="alert alert-info border-0 rounded-3 shadow-sm py-2 px-3 mb-0 w-100">
                                <small class="fw-bold"><i class="fas fa-info-circle me-1"></i> Reward points are automatically assigned based on difficulty.</small>
                            </div>
                        </div>
                    </div>

                    @if (User.IsInRole("Admin"))
                    {
                        <div class="mb-4">
                            <div class="form-check form-switch p-3 bg-light rounded-3 shadow-sm border border-primary border-opacity-10">
                                <input class="form-check-input ms-0 me-3" type="checkbox" asp-for="IsPublic">
                                <label class="form-check-label fw-bold" asp-for="IsPublic"><i class="fas fa-globe me-1 text-primary"></i> Make this challenge public</label>
                                <div class="form-text mt-2 ps-1">Global challenges are visible to the entire community.</div>
                            </div>
                        </div>
                    }

                    <div class="d-flex justify-content-between align-items-center border-top pt-4">
                        <a asp-action="Index" class="btn btn-link text-secondary text-decoration-none">
                            <i class="fas fa-arrow-left me-1"></i> Back to List
                        </a>
                        <button type="submit" class="btn btn-primary px-5 py-2 fw-bold shadow-sm">
                            <i class="fas fa-save me-2"></i> Create Challenge
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
