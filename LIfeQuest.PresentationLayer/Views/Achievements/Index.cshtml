@model IEnumerable<LifeQuest.BLL.DTOs.BadgeDTO>
@{
    ViewData["Title"] = "Achievements";
    var userBadgeIds = ViewBag.UserBadgeIds as List<int> ?? new List<int>();
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="fw-bold mb-2 display-4" style="text-shadow: 0 4px 10px rgba(26, 35, 126, 0.2); color: var(--primary-color);">Honors & Achievements</h1>
        <p class="text-muted lead">Explore the milestones you've unlocked on your journey.</p>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var badge in Model)
            {
                bool isEarned = userBadgeIds.Contains(badge.Id);
                <div class="col-md-4 col-lg-3">
                    <div class="card h-100 border-0 shadow-sm rounded-4 text-center p-4 @(isEarned ? "badge-earned" : "badge-locked")">
                        <div class="badge-icon-container mb-3 mx-auto @(isEarned ? "earned-icon-bg" : "locked-icon-bg")">
                            <i class="fas @(badge.Image ?? "fa-medal") @(isEarned ? "text-primary" : "text-muted")"></i>
                        </div>
                        <h5 class="fw-bold mb-1" style="color: var(--primary-color);">@badge.Name</h5>
                        <p class="small text-muted mb-3">@badge.Description</p>
                        
                        @if (isEarned)
                        {
                            <span class="badge bg-success rounded-pill px-3 py-2 mt-auto">
                                <i class="fas fa-check-circle me-1"></i> Earned
                            </span>
                        }
                        else
                        {
                            <div class="mt-auto">
                                <span class="badge bg-secondary rounded-pill px-3 py-2">
                                    <i class="fas fa-lock me-1"></i> Locked
                                </span>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

<style>
    .badge-icon-container {
        width: 80px;
        height: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        font-size: 2.5rem;
        transition: transform 0.3s ease;
        border: 2px solid rgba(0,0,0,0.05);
    }
    .earned-icon-bg { background-color: rgba(26, 35, 126, 0.1); }
    .locked-icon-bg { background-color: rgba(0, 0, 0, 0.05); }
    
    .badge-earned { border-top: 5px solid var(--primary-color) !important; }
    .badge-locked { filter: grayscale(1); opacity: 0.7; background-color: rgba(0, 0, 0, 0.02) !important; }
    
    .card:hover { transform: translateY(-10px); }
    .badge-earned:hover .badge-icon-container { transform: scale(1.1) rotate(5deg); box-shadow: 0 4px 15px rgba(26, 35, 126, 0.2); }
</style>
