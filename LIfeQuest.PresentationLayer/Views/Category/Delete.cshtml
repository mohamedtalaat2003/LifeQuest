@model LifeQuest.BLL.DTOs.CategoryDTO
@{
    ViewData["Title"] = "Delete Category";
}

<div class="container py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">
                    <div class="text-danger mb-4">
                        <i class="fas fa-exclamation-triangle fa-4x"></i>
                    </div>
                    <h2 class="fw-bold mb-3">Are you sure?</h2>
                    <p class="text-muted mb-4">
                        You are about to delete <strong>@Model.Name</strong>. This action may affect existing challenges linked to this category.
                    </p>

                    <form asp-action="DeleteConfirmed" method="post">
                        <input type="hidden" asp-for="Id" name="id" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill shadow-sm">
                                <i class="fas fa-trash me-2"></i> Confirm Deletion
                            </button>
                            <a asp-action="Index" class="btn btn-light rounded-pill">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
