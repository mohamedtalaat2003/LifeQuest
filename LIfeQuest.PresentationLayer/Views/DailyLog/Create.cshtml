@model LifeQuest.BLL.DTOs.DailyLogDTO
@{
    ViewData["Title"] = "Log Activity";
    var activeChallenges = ViewBag.ActiveChallenges as List<LifeQuest.BLL.DTOs.UserChallengeDTO>;
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow border-0 rounded-4">
                <div class="card-body p-5">
                    <h2 class="fw-bold mb-4 text-center">Log Today's Progress</h2>
                    <p class="text-muted text-center mb-5">Keep your streak alive by recording your efforts!</p>

                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="ChallengeId" class="form-label fw-bold">Select Challenge</label>
                            <select asp-for="ChallengeId" class="form-select border-0 bg-light rounded-3 p-3">
                                <option value="">-- Choose a Quest --</option>
                                @if (activeChallenges != null)
                                {
                                    foreach (var uc in activeChallenges)
                                    {
                                        <option value="@uc.ChallengeId">@uc.ChallengeName</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="ChallengeId" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Duration" class="form-label fw-bold">Effort (Minutes/Units)</label>
                            <div class="input-group">
                                <span class="input-group-text border-0 bg-light rounded-start-3 px-3"><i class="fas fa-stopwatch"></i></span>
                                <input asp-for="Duration" type="number" class="form-control border-0 bg-light rounded-end-3 p-3" placeholder="How long did you spend?">
                            </div>
                            <span asp-validation-for="Duration" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Notes" class="form-label fw-bold">Reflections / Notes</label>
                            <textarea asp-for="Notes" class="form-control border-0 bg-light rounded-3 p-3" rows="3" placeholder="What went well today?"></textarea>
                            <span asp-validation-for="Notes" class="text-danger small"></span>
                        </div>

                        <input type="hidden" asp-for="LogDate" value="@DateTime.Now.ToString("yyyy-MM-dd")" />

                        <div class="d-grid gap-2 pt-3">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill shadow-sm">Save Log Entry</button>
                            <a asp-controller="Dashboard" asp-action="Index" class="btn btn-link text-decoration-none">Back to Dashboard</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
