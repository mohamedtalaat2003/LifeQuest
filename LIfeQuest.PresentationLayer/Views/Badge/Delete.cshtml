@model LifeQuest.BLL.DTOs.BadgeDTO
@{
    ViewData["Title"] = "Delete Badge";
}

<div class="container py-5 text-center">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-5">
                    <div class="text-danger mb-4">
                        <i class="fas fa-trash-alt fa-4x"></i>
                    </div>
                    <h2 class="fw-bold mb-3">Void Honor?</h2>
                    <p class="text-muted mb-4">
                        Are you sure you want to delete the <strong>@Model.Name</strong> badge? This cannot be undone and users will lose this achievement.
                    </p>

                    <form asp-action="DeleteConfirmed" method="post">
                        <input type="hidden" asp-for="Id" name="id" />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg rounded-pill shadow-sm">
                                <i class="fas fa-trash me-2"></i> Permanently Delete
                            </button>
                            <a asp-action="Index" class="btn btn-light rounded-pill">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
