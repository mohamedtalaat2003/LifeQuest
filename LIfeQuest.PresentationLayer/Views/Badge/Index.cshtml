@model IEnumerable<LifeQuest.BLL.DTOs.BadgeDTO>
@{
    ViewData["Title"] = "Manage Badges";
}

<div class="container py-4">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800 fw-bold">Badge Library</h1>
            <p class="text-muted small">Design and manage the honors users can earn.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="fas fa-medal me-2"></i> Create New Badge
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4 py-3">Badge</th>
                            <th class="py-3">Details</th>
                            <th class="py-3 text-center">Reward</th>
                            <th class="py-3">Requirements</th>
                            <th class="text-end pe-4 py-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-light rounded-circle d-flex align-items-center justify-content-center me-3" style="width: 50px; height: 50px; font-size: 1.5rem;">
                                            <i class="fas @(item.Image ?? "fa-medal") text-primary"></i>
                                        </div>
                                        <div class="fw-bold text-dark">@item.Name</div>
                                    </div>
                                </td>
                                <td>
                                    <div class="small text-muted" style="max-width: 250px;">@item.Description</div>
                                </td>
                                <td class="text-center">
                                    <span class="badge bg-success bg-opacity-10 text-success border px-2">
                                        +@item.Points pts
                                    </span>
                                </td>
                                <td>
                                    <div class="small fw-bold">
                                        @if (item.CriteriaType == "Level") {
                                            <i class="fas fa-layer-group text-info me-1"></i> @item.RequiredLevelName
                                        } else {
                                            <i class="fas fa-tasks text-warning me-1"></i> @item.CriteriaValue @item.CriteriaType
                                        }
                                    </div>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill me-2">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger rounded-pill">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
