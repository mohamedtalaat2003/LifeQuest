@model IEnumerable<LifeQuest.BLL.DTOs.BadgeDTO>
@{
    ViewData["Title"] = "Achievements";
    var userBadgeIds = ViewBag.UserBadgeIds as List<int> ?? new List<int>();
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="fw-bold mb-2">Honors & Achievements</h1>
        <p class="text-muted">Explore the milestones you've unlocked on your journey.</p>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var badge in Model)
            {
                bool isEarned = userBadgeIds.Contains(badge.Id);
                <div class="col-md-4 col-lg-3">
                    <div class="card h-100 border-0 shadow-sm rounded-4 text-center p-4 @(isEarned ? "badge-earned" : "badge-locked")">
                        <div class="badge-icon-container mb-3 mx-auto @(isEarned ? "bg-warning bg-opacity-25" : "bg-light")">
                            <i class="fas @(badge.Image ?? "fa-medal") @(isEarned ? "text-warning" : "text-muted opacity-50")"></i>
                        </div>
                        <h5 class="fw-bold mb-1">@badge.Name</h5>
                        <p class="small text-muted mb-3">@badge.Description</p>
                        
                        @if (isEarned)
                        {
                            <span class="badge bg-success rounded-pill px-3 py-2 mt-auto">
                                <i class="fas fa-check-circle me-1"></i> Earned
                            </span>
                        }
                        else
                        {
                            <div class="mt-auto">
                                @if (!string.IsNullOrEmpty(badge.RequiredLevelName))
                                {
                                    <div class="small text-warning mb-2 fw-bold">
                                        <i class="fas fa-lock-open me-1"></i> Level: @badge.RequiredLevelName
                                    </div>
                                }
                                <span class="badge bg-light text-muted rounded-pill px-3 py-2">
                                    <i class="fas fa-lock me-1"></i> Locked
                                </span>
                            </div>
                        }
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center py-5">
                <div class="opacity-25 mb-4">
                    <i class="fas fa-award fa-5x"></i>
                </div>
                <h3>No achievements found.</h3>
                <p class="text-muted">Start completing challenges to earn your first medal!</p>
            </div>
        }
    </div>
</div>

<style>
    .badge-icon-container {
        width: 80px;
        height: 80px;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 50%;
        font-size: 2.5rem;
        transition: transform 0.3s ease;
    }
    .badge-earned { border-top: 5px solid #ffc107 !important; }
    .badge-locked { filter: grayscale(1); opacity: 0.7; }
    .card { transition: all 0.3s ease; }
    .card:hover { transform: translateY(-10px); }
    .badge-earned:hover .badge-icon-container { transform: scale(1.1) rotate(5deg); }
</style>
