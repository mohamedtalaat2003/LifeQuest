@model IEnumerable<LifeQuest.BLL.DTOs.LevelDTO>
@{
    ViewData["Title"] = "Manage Levels";
}

<div class="container py-4">
    <div class="d-sm-flex align-items-center justify-content-between mb-4">
        <div>
            <h1 class="h3 mb-0 text-gray-800 fw-bold">Rank Progression</h1>
            <p class="text-muted small">Define the levels and point thresholds for your users.</p>
        </div>
        <a asp-action="Create" class="btn btn-primary rounded-pill px-4 shadow-sm">
            <i class="fas fa-layer-group me-2"></i> Add New Level
        </a>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light text-muted small text-uppercase">
                        <tr>
                            <th class="ps-4 py-3">Order</th>
                            <th class="py-3">Level Name</th>
                            <th class="py-3">Points Required</th>
                            <th class="text-end pe-4 py-3">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.OrderBy(l => l.LevelsCount))
                        {
                            <tr>
                                <td class="ps-4 text-center">
                                    <div class="bg-primary bg-opacity-10 text-primary rounded-circle fw-bold d-inline-flex align-items-center justify-content-center" style="width: 35px; height: 35px;">
                                        @item.LevelsCount
                                    </div>
                                </td>
                                <td>
                                    <div class="fw-bold text-dark fs-5">@item.LevelName</div>
                                </td>
                                <td>
                                    <span class="badge bg-warning bg-opacity-10 text-warning border px-3">
                                        <i class="fas fa-star me-1"></i> @item.Point.ToString("N0") pts
                                    </span>
                                </td>
                                <td class="text-end pe-4">
                                    <div class="btn-group">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary rounded-pill me-2">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger rounded-pill">
                                            <i class="fas fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
