@{
    Layout = "_AccountLayout";
    ViewData["Title"] = "Check Your Email";
}

<div class="text-center">
    <div class="mb-4">
        <i class="fas fa-envelope-open-text fa-4x text-primary animate__animated animate__bounceIn"></i>
    </div>
    <h4 class="fw-bold mb-3">Check Your Email</h4>
    <p class="text-muted mb-4">
        We've sent a confirmation link to your email address. Please click the link to verify your account and start your journey.
    </p>
    <div class="d-grid gap-2">
        <a asp-action="Login" class="btn btn-primary shadow-sm fw-bold">Return to Login</a>
    </div>
    <div class="mt-4 pt-4 border-top">
        <p class="small text-muted mb-0">
            Didn't receive the email? <br />
            Check your spam folder or <a asp-action="Login" class="text-decoration-none fw-bold">try again</a>.
        </p>
    </div>
</div>
