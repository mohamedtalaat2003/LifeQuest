@model LifeQuest.PL.ViewModels.LoginVM

@{
    Layout = "_AccountLayout";
    ViewData["Title"] = "Login";
}

<div class="mb-4">
    <h2 class="fw-bold text-dark mb-1">Sign In</h2>
    <p class="text-muted">Welcome back! Please enter your details.</p>
</div>

<div asp-validation-summary="All" class="text-danger mb-4 small fw-bold"></div>

<form asp-action="Login" asp-controller="Account" method="post" class="auth-form">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label asp-for="UserName" class="form-label small fw-bold text-secondary">Username</label>
        <div class="input-group">
            <span class="input-group-text bg-light border-end-0"><i class="fas fa-user text-muted"></i></span>
            <input asp-for="UserName" class="form-control bg-light border-start-0 ps-0" placeholder="Username" />
        </div>
        <span asp-validation-for="UserName" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <div class="d-flex justify-content-between">
            <label asp-for="PlainPassword" class="form-label small fw-bold text-secondary">Password</label>
            <a asp-action="ForgotPassword" asp-controller="Account" class="small text-primary fw-bold text-decoration-none">Forgot?</a>
        </div>
        <div class="input-group">
            <span class="input-group-text bg-light border-end-0"><i class="fas fa-lock text-muted"></i></span>
            <input asp-for="PlainPassword" type="password" class="form-control bg-light border-start-0 ps-0" placeholder="••••••••" />
        </div>
        <span asp-validation-for="PlainPassword" class="text-danger small"></span>
    </div>

    <div class="mb-4 d-flex justify-content-between align-items-center">
        <div class="form-check">
            <input asp-for="RememberMe" class="form-check-input" />
            <label asp-for="RememberMe" class="form-check-label small text-muted">Remember me</label>
        </div>
    </div>

    <div class="d-grid mb-4">
        <button type="submit" class="btn btn-primary btn-lg py-3 shadow-sm fw-bold">Sign In</button>
    </div>

    <div class="divider mb-4">
        <span class="px-3 small text-muted text-uppercase fw-bold bg-white position-relative z-index-1" style="font-size: 0.65rem; letter-spacing: 1px;">Or continue with</span>
        <div class="position-absolute top-50 start-0 w-100 border-bottom"></div>
    </div>
</form>

<div class="row g-2 mb-4">
    <div class="col-6">
        <form asp-action="ExternalLogin" asp-controller="Account" asp-route-provider="Google" method="post">
            <button type="submit" class="social-auth-btn w-100" title="Log in using Google">
                <i class="fab fa-google me-2 text-danger"></i> Google
            </button>
        </form>
    </div>
    <div class="col-6">
        <form asp-action="ExternalLogin" asp-controller="Account" asp-route-provider="GitHub" method="post">
            <button type="submit" class="social-auth-btn w-100" title="Log in using GitHub">
                <i class="fab fa-github me-2 text-dark"></i> GitHub
            </button>
        </form>
    </div>
</div>

<div class="text-center mt-5">
    <p class="text-muted small mb-0">No account? <a asp-action="Register" asp-controller="Account" class="text-primary fw-bold text-decoration-none">Join the Quest</a></p>
</div>

