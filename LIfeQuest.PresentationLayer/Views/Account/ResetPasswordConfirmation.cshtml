@{
    Layout = "_AccountLayout";
    ViewData["Title"] = "Password Reset Success";
}

<div class="text-center">
    <div class="mb-4">
        <i class="fas fa-lock text-success" style="font-size: 4rem;"></i>
    </div>
    <h4 class="fw-bold mb-2">Password Reset Successful</h4>
    <p class="text-muted mb-4">Your password has been changed successfully. You can now use your new password to sign in.</p>
    
    <div class="d-grid">
        <a asp-action="Login" asp-controller="Account" class="btn btn-primary btn-lg shadow-sm fw-bold">
            Sign In
        </a>
    </div>
</div>
