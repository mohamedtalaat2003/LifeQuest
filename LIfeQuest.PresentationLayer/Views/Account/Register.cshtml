@model LifeQuest.PL.ViewModels.RegistrationVM

@{
    Layout = "_AccountLayout";
    ViewData["Title"] = "Register";
}

<div class="text-center mb-4">
    <h4 class="fw-bold mb-1">Create Account</h4>
    <p class="text-muted small">Start your journey and transform your habits today.</p>
</div>

<div asp-validation-summary="All" class="text-danger mb-2"></div>

<form asp-action="Register" asp-controller="Account" method="post" class="auth-form">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label asp-for="Name" class="form-label small fw-bold text-muted">Full Name</label>
        <input asp-for="Name" class="form-control" placeholder="John Doe">
        <span asp-validation-for="Name" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="UserName" class="form-label small fw-bold text-muted">User Name</label>
        <input asp-for="UserName" class="form-control" placeholder="johndoe123">
        <span asp-validation-for="UserName" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Email" class="form-label small fw-bold text-muted">Email Address</label>
        <input asp-for="Email" class="form-control" placeholder="name@example.com">
        <span asp-validation-for="Email" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="PlainPassword" class="form-label small fw-bold text-muted">Password</label>
        <input asp-for="PlainPassword" type="password" class="form-control" placeholder="At least 8 characters">
        <span asp-validation-for="PlainPassword" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="ConfirmPassword" class="form-label small fw-bold text-muted">Confirm Password</label>
        <input asp-for="ConfirmPassword" type="password" class="form-control">
        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Country" class="form-label small fw-bold text-muted">Country</label>
        <select asp-for="Country" asp-items="Model.Countries" class="form-control">
            <option value="">-- Select Country --</option>
        </select>
        <span asp-validation-for="Country" class="text-danger small"></span>
    </div>

    <div class="mb-4">
        <p class="xsmall text-muted">
            By clicking Register, you agree to our
            <a href="#">Terms</a> and <a href="#">Privacy Policy</a>.
        </p>
    </div>

    <div class="d-grid mb-4">
        <button type="submit" class="btn btn-primary btn-lg shadow-sm fw-bold">
            Register
        </button>
    </div>

    <div class="text-center">
        <p class="small text-muted mb-0">
            Already have an account?
            <a asp-action="Login" asp-controller="Account" class="fw-bold text-decoration-none">Sign In</a>
        </p>
    </div>
</form>

</html>