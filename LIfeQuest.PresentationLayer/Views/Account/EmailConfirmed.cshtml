@{
    Layout = "_AccountLayout";
    ViewData["Title"] = "Email Confirmed";
}

<div class="text-center">
    <div class="mb-4">
        <i class="fas fa-check-circle text-success" style="font-size: 4rem;"></i>
    </div>
    <h4 class="fw-bold mb-2">Email Confirmed!</h4>
    <p class="text-muted mb-4">Your email has been successfully verified. You can now access all features of Life Quest.</p>
    
    <div class="d-grid">
        <a asp-action="Login" asp-controller="Account" class="btn btn-primary btn-lg shadow-sm fw-bold">
            Sign In Now
        </a>
    </div>
</div>
