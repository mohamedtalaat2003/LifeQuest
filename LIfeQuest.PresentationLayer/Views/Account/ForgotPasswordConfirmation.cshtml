@{
    Layout = "_AccountLayout";
    ViewData["Title"] = "Check Your Email";
}

<div class="text-center">
    <div class="mb-4">
        <i class="fas fa-paper-plane text-primary" style="font-size: 4rem;"></i>
    </div>
    <h4 class="fw-bold mb-2">Check Your Email</h4>
    <p class="text-muted mb-4">We've sent a password reset link to your email address. Please check your inbox (and spam folder) to continue.</p>
    
    <div class="d-grid">
        <a href="/" class="btn btn-outline-primary btn-lg fw-bold">
            Back to Home
        </a>
    </div>
</div>
