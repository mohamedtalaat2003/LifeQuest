@{
    ViewData["Title"] = "Access Denied";
    Layout = "_Layout";
}

<div class="container h-100 d-flex align-items-center justify-content-center py-5">
    <div class="text-center p-5 shadow-lg rounded-4 bg-white border-0" style="max-width: 600px;">
        <div class="mb-4">
            <div class="display-1 text-danger opacity-25 fw-bold mb-0">403</div>
            <div class="bg-danger bg-opacity-10 text-danger rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 100px; height: 100px;">
                <i class="fas fa-user-shield fa-4x"></i>
            </div>
        </div>
        
        <h1 class="fw-bold text-dark mb-3">Access Denied</h1>
        <p class="text-muted fs-5 mb-4">
            Oops! It looks like you've stumbled into a restricted territory. Your current role doesn't have the permissions required to view this page.
        </p>
        
        <div class="d-grid gap-2 d-sm-flex justify-content-sm-center">
            <a href="/" class="btn btn-primary btn-lg rounded-pill px-5 shadow-sm">
                <i class="fas fa-home me-2"></i> Back to Dashboard
            </a>
            <a asp-controller="Account" asp-action="Logout" onclick="document.forms[0].submit(); return false;" class="btn btn-outline-secondary btn-lg rounded-pill px-5">
                Switch Account
            </a>
            <form asp-action="Logout" asp-controller="Account" method="post" style="display:none;"></form>
        </div>
        
        <div class="mt-5 pt-4 border-top">
            <p class="small text-muted mb-0">
                If you believe this is an error, please contact your system administrator.
            </p>
        </div>
    </div>
</div>
