@model LifeQuest.PL.ViewModels.ForgotPasswordVM

@{
    Layout = "_AccountLayout";
    ViewData["Title"] = "Forgot Password";
}

<div class="text-center mb-4">
    <h4 class="fw-bold mb-1">Forgot Password?</h4>
    <p class="text-muted small">No worries! Enter your email and we'll send you a reset link.</p>
</div>

<div asp-validation-summary="All" class="text-danger mb-2"></div>

<form asp-action="ForgotPassword" asp-controller="Account" method="post" class="auth-form">
    @Html.AntiForgeryToken()

    <div class="mb-4">
        <label asp-for="Email" class="form-label small fw-bold text-muted">Email Address</label>
        <input asp-for="Email" class="form-control" placeholder="name@example.com" />
        <span asp-validation-for="Email" class="text-danger small"></span>
    </div>

    <div class="d-grid mb-4">
        <button type="submit" class="btn btn-primary btn-lg shadow-sm fw-bold">Send Reset Link</button>
    </div>

    <div class="text-center">
        <p class="small text-muted mb-0">Remembered your password? <a asp-action="Login" asp-controller="Account" class="fw-bold text-decoration-none">Sign In</a></p>
    </div>
</form>
