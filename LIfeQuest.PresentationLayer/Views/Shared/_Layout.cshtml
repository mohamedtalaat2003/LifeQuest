@using Microsoft.AspNetCore.Identity
@using LifeQuest.DAL.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Life Quest</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet">
    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div id="wrapper">
        <!-- Sidebar -->
        <nav id="sidebar">
            <a href="/" class="sidebar-brand">
                <i class="fas fa-rocket me-2"></i> Life Quest
            </a>
            <hr class="mx-3 my-0 border-light opacity-10">
            <ul class="nav flex-column mt-3">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Dashboard" asp-action="Index">
                        <i class="fas fa-th-large"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Challenges" ? "active" : "")" asp-controller="Challenges" asp-action="Index">
                        <i class="fas fa-trophy"></i> My Challenges
                    </a>
                </li>
                <li class="nav-item">
                <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Achievements") ? "active bg-primary bg-opacity-10 text-primary fw-bold" : "text-muted")"
                   asp-controller="Achievements" asp-action="Index">
                    <i class="fas fa-award me-3"></i>
                    <span>Achievements</span>
                </a>
            </li>    <!-- Decisions Module -->
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Decision" ? "active" : "")" asp-controller="Decision" asp-action="Index">
                        <i class="fas fa-balance-scale"></i> Decisions
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Analytics" ? "active" : "")" asp-controller="Analytics" asp-action="Index">
                        <i class="fas fa-chart-line"></i> Analytics
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "UserProfile" ? "active" : "")" asp-controller="UserProfile" asp-action="Details">
                        <i class="fas fa-user-circle"></i> Profile
                    </a>
                </li>

                @if (User.IsInRole("Admin"))
                {
                    <hr class="mx-3 my-2 border-light opacity-10">
                    <li class="px-3 mb-2 mt-2"><small class="text-uppercase fw-bold text-muted small" style="font-size: 0.65rem;">Admin Portal</small></li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Category" ? "active" : "")" asp-controller="Category" asp-action="Index">
                            <i class="fas fa-tags"></i> Categories
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Level" ? "active" : "")" asp-controller="Level" asp-action="Index">
                            <i class="fas fa-layer-group"></i> Levels
                        </a>
                    </li>
                }
            </ul>
        </nav>

        <!-- Content Wrapper -->
        <div id="content-wrapper">
            <!-- Top Navbar -->
            <nav class="top-navbar bg-white">
                <div class="d-flex align-items-center w-100">
                    <button class="btn btn-link d-md-none me-3" id="sidebarToggle">
                        <i class="fa fa-bars"></i>
                    </button>
                    
                    <div class="ms-auto d-flex align-items-center">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            var currentUser = await UserManager.GetUserAsync(User);
                            var displayName = currentUser?.Name ?? currentUser?.UserName ?? "User";
                            <div class="me-4 d-none d-sm-inline-block">
                                <span class="points-indicator me-2"><i class="fas fa-coins"></i> @(ViewData["UserPoints"] ?? "0") pts</span>
                                <span class="level-badge">@(ViewData["UserLevel"] ?? "Novice")</span>
                            </div>
                            
                            <!-- Notifications Dropdown -->
                            <div class="dropdown me-3">
                                @await Component.InvokeAsync("Notifications")
                            </div>
                            
                            <div class="d-flex align-items-center border-start ps-3">
                                <span class="me-2 d-none d-lg-inline text-gray-600 small fw-bold">@displayName</span>
                                @if (ViewData["ProfilePicture"] != null)
                                {
                                    <img class="avatar-sm rounded-circle" src="@ViewData["ProfilePicture"]" alt="User" style="object-fit: cover;">
                                }
                                else
                                {
                                    <img class="avatar-sm rounded-circle" src="https://ui-avatars.com/api/?name=@(Uri.EscapeDataString(displayName))&background=4e73df&color=fff" alt="User" style="object-fit: cover;">
                                }
                                <form asp-action="Logout" asp-controller="Account" method="post" class="ms-3 m-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm" title="Logout">
                                        <i class="fas fa-sign-out-alt"></i>
                                    </button>
                                </form>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex gap-2">
                                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-sm fw-bold">Login</a>
                                <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-sm fw-bold">Register</a>
                            </div>
                        }
                    </div>
                </div>
            </nav>

            <!-- Main Body -->
            <div class="container-fluid py-4">
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4 border-start border-4 border-danger" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i> @TempData["ErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4 border-start border-4 border-success" role="alert">
                        <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @RenderBody()
            </div>

            <footer class="py-4 bg-white mt-auto border-top">
                <div class="container-fluid">
                    <div class="d-flex align-items-center justify-content-between small">
                        <div class="text-muted">&copy; 2026 Life Quest Dashboard</div>
                        <div>
                            <a href="#">Privacy Policy</a>
                            &middot;
                            <a href="#">Terms &amp; Conditions</a>
                        </div>
                    </div>
                </div>
            </footer>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>