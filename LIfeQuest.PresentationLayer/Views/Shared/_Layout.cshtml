@using Microsoft.AspNetCore.Identity
@using LifeQuest.DAL.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Life Quest</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,200i,300,300i,400,400i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet">
    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <div id="wrapper">
        <!-- Sidebar -->
        <nav id="sidebar">
            <a href="/" class="sidebar-brand mb-2">
                <div class="bg-primary bg-opacity-10 text-primary p-2 rounded-3 me-2 d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                    <i class="fas fa-rocket"></i>
                </div>
                Life Quest
            </a>
            <hr class="mx-3 my-2 border-dark opacity-5">
            <ul class="nav flex-column mt-2">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Dashboard" asp-action="Index">
                        <i class="fas fa-th-large"></i> Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Challenges" ? "active" : "")" asp-controller="Challenges" asp-action="Index">
                        <i class="fas fa-trophy"></i> Quest Board
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(Context.Request.Path.StartsWithSegments("/Achievements") ? "active" : "")"
                       asp-controller="Achievements" asp-action="Index">
                        <i class="fas fa-award"></i> Achievements
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Decision" ? "active" : "")" asp-controller="Decision" asp-action="Index">
                        <i class="fas fa-balance-scale"></i> Decisions
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Analytics" ? "active" : "")" asp-controller="Analytics" asp-action="Index">
                        <i class="fas fa-chart-line"></i> Analytics
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "UserProfile" ? "active" : "")" asp-controller="UserProfile" asp-action="Details">
                        <i class="fas fa-user-circle"></i> Profile
                    </a>
                </li>

                @if (User.IsInRole("Admin"))
                {
                    <hr class="mx-3 my-3 border-dark opacity-5">
                    <li class="px-4 mb-2"><small class="text-uppercase fw-bold text-muted" style="font-size: 0.65rem; letter-spacing: 1px;">Admin Portal</small></li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Category" ? "active" : "")" asp-controller="Category" asp-action="Index">
                            <i class="fas fa-tags"></i> Categories
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Level" ? "active" : "")" asp-controller="Level" asp-action="Index">
                            <i class="fas fa-layer-group"></i> Levels
                        </a>
                    </li>
                }
            </ul>
        </nav>

        <!-- Content Wrapper -->
        <div id="content-wrapper">
            <!-- Top Navbar -->
            <nav class="top-navbar">
                <div class="d-flex align-items-center w-100">
                    <button class="btn btn-light d-md-none me-3 rounded-3" id="sidebarToggle">
                        <i class="fa fa-bars text-primary"></i>
                    </button>
                    
                    <div class="ms-auto d-flex align-items-center">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            var currentUser = await UserManager.GetUserAsync(User);
                            var displayName = currentUser?.Name ?? currentUser?.UserName ?? "User";
                            <div class="me-4 d-none d-sm-inline-flex align-items-center gap-3">
                                <span class="points-indicator"><i class="fas fa-coins me-1"></i> @(ViewData["UserPoints"] ?? "0") pts</span>
                                <span class="level-badge">@(ViewData["UserLevel"] ?? "Novice")</span>
                            </div>
                            
                            <!-- Notifications Dropdown -->
                            <div class="dropdown me-3">
                                @await Component.InvokeAsync("Notifications")
                            </div>
                            
                            <div class="d-flex align-items-center border-start ps-3 gap-3">
                                <span class="d-none d-lg-inline text-dark small fw-bold">@displayName</span>
                                <div class="position-relative">
                                    @if (ViewData["ProfilePicture"] != null)
                                    {
                                        <img class="avatar-sm" src="@ViewData["ProfilePicture"]" alt="User">
                                    }
                                    else
                                    {
                                        <img class="avatar-sm" src="https://ui-avatars.com/api/?name=@(Uri.EscapeDataString(displayName))&background=1a237e&color=fff" alt="User">
                                    }
                                </div>
                                <form asp-action="Logout" asp-controller="Account" method="post" class="m-0">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-3 px-3" title="Logout">
                                        <i class="fas fa-sign-out-alt"></i>
                                    </button>
                                </form>
                            </div>
                        }
                        else
                        {
                            <div class="d-flex gap-2">
                                <a asp-controller="Account" asp-action="Login" class="btn btn-outline-primary btn-sm rounded-pill px-4 fw-bold">Login</a>
                                <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-sm rounded-pill px-4 fw-bold shadow-sm">Get Started</a>
                            </div>
                        }
                    </div>
                </div>
            </nav>

            <!-- Main Body -->
            <div class="container-fluid py-4 animate__animated animate__fadeIn">
                @if (TempData["ErrorMessage"] != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show shadow-sm mb-4 border-0 rounded-4 p-3 ps-4 border-start border-4 border-danger" role="alert">
                        <i class="fas fa-exclamation-circle me-2"></i> @TempData["ErrorMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show shadow-sm mb-4 border-0 rounded-4 p-3 ps-4 border-start border-4 border-success" role="alert">
                        <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }
                @RenderBody()
            </div>

            <footer class="py-4 bg-white mt-auto border-top border-light">
                <div class="container-fluid">
                    <div class="d-flex align-items-center justify-content-between small">
                        <div class="text-muted fw-bold">&copy; 2026 Life Quest &middot; Level Up Your Life</div>
                        <div class="d-flex gap-3">
                            <a href="#" class="text-decoration-none text-secondary hover-primary">Privacy Policy</a>
                            <a href="#" class="text-decoration-none text-secondary hover-primary">Terms &amp; Conditions</a>
                        </div>
                    </div>
                </div>
            </footer>
        </div>
    </div>


    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>