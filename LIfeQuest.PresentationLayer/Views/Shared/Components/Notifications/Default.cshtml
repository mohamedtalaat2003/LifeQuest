@model IEnumerable<LifeQuest.BLL.DTOs.NotificationDTO>

<a class="nav-link text-secondary" href="#" id="alertsDropdown" role="button"
   data-bs-toggle="dropdown" aria-haspopup="true" aria-expanded="false">
    <div class="position-relative d-inline-block">
        <i class="fas fa-bell fa-lg"></i>
        @if (Model.Any())
        {
            <!-- Counter - Alerts -->
            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.55rem; padding: 0.25em 0.4em;">
                @Model.Count()
            </span>
        }
    </div>
</a>
<!-- Dropdown - Alerts -->
<div class="dropdown-list dropdown-menu dropdown-menu-end shadow-sm border-0 rounded-4 animated--grow-in mt-2 p-0"
     aria-labelledby="alertsDropdown" style="min-width: 320px; max-width: 360px;">
    
    <div class="dropdown-header bg-primary text-white fw-bold py-3 px-3 rounded-top d-flex justify-content-between align-items-center">
        <span><i class="fas fa-bell me-2"></i> Activity Center</span>
        <span class="badge bg-white text-primary rounded-pill">@(Model.Count()) New</span>
    </div>
    
    @if (!Model.Any())
    {
        <div class="dropdown-item text-center small text-muted py-4">
            <i class="fas fa-inbox fa-3x mb-3 opacity-25"></i>
            <p class="mb-0">No new activity yet.</p>
        </div>
    }
    else
    {
        <div style="max-height: 350px; overflow-y: auto;">
            @foreach (var notification in Model)
            {
                var timeSpan = DateTime.Now - notification.Date;
                var timeAgo = "";
                
                if (timeSpan.TotalHours < 1) {
                    timeAgo = $"{(int)timeSpan.TotalMinutes}m ago";
                } else if (timeSpan.TotalHours < 24) {
                    timeAgo = $"{(int)timeSpan.TotalHours}h ago";
                } else {
                    timeAgo = $"{(int)timeSpan.TotalDays}d ago";
                }

                <a class="dropdown-item d-flex align-items-center py-3 border-bottom text-wrap" href="@notification.Link">
                    <div class="me-3">
                        <div class="icon-circle @notification.ColorClass d-flex align-items-center justify-content-center rounded-circle" style="width: 45px; height: 45px; flex-shrink:0;">
                            <i class="fas @notification.Icon"></i>
                        </div>
                    </div>
                    <div style="min-width: 0;">
                        <span class="fw-bold d-block text-truncate" style="white-space: normal; line-height: 1.2;">@notification.Message</span>
                        <div class="small text-muted mt-1"><i class="far fa-clock me-1"></i> @timeAgo</div>
                    </div>
                </a>
            }
        </div>
        <a class="dropdown-item text-center small text-primary py-3 fw-bold bg-light rounded-bottom" href="/Dashboard">
            View Dashboard for More
        </a>
    }
</div>
