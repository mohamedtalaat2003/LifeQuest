<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Life Quest</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,300,400,600,700,800,900" rel="stylesheet">
    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <!-- Animate.css -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body class="bg-light">

    <div class="auth-split-container">
        <!-- Hero Area -->
        <div class="auth-side-image animate__animated animate__fadeIn">
            <div class="auth-header-icon mb-4">
                <i class="fas fa-rocket fa-2x text-white"></i>
            </div>
            <h1 class="display-4 fw-800 text-white mb-3">Life Quest</h1>
            <p class="fs-5 text-white opacity-80 text-center px-5 mb-5">
                Level up your life, one habit at a time. Join our community of high-achievers.
            </p>
            
            <div class="d-flex gap-4 mt-5 opacity-50">
                <div class="text-center">
                    <h3 class="fw-bold mb-0">10k+</h3>
                    <small class="text-uppercase" style="font-size: 0.6rem; letter-spacing: 1px;">Heroes</small>
                </div>
                <div class="vr"></div>
                <div class="text-center">
                    <h3 class="fw-bold mb-0">50k+</h3>
                    <small class="text-uppercase" style="font-size: 0.6rem; letter-spacing: 1px;">Quests</small>
                </div>
                <div class="vr"></div>
                <div class="text-center">
                    <h3 class="fw-bold mb-0">1M+</h3>
                    <small class="text-uppercase" style="font-size: 0.6rem; letter-spacing: 1px;">Points</small>
                </div>
            </div>
        </div>

        <!-- Form Area -->
        <div class="auth-side-form animate__animated animate__slideInRight animate__faster">
            <div class="auth-card-clean">
                @RenderBody()
            </div>
        </div>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation-unobtrusive@3.2.12/dist/jquery.validate.unobtrusive.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>

