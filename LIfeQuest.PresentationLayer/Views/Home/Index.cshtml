@{
    Layout = null;
}
@using Microsoft.AspNetCore.Identity
@using LifeQuest.DAL.Models
@inject SignInManager<ApplicationUser> SignInManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Life Quest - Transform Your Life Into a Game</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css?family=Nunito:200,300,400,600,700,800,900" rel="stylesheet">
    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <!-- Top Navigation Bar -->
    <nav class="navbar navbar-expand-lg landing-navbar sticky-top shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-extrabold text-primary d-flex align-items-center" href="#">
                <i class="fas fa-rocket me-2"></i> Life Quest
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav mx-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link fw-bold px-3" href="#features">Features</a></li>
                    <li class="nav-item"><a class="nav-link fw-bold px-3" href="#challenges">How It Works</a></li>
                    <li class="nav-item"><a class="nav-link fw-bold px-3" href="/Analytics">Analytics</a></li>
                </ul>
                <div class="d-flex gap-2">
                    @if (SignInManager.IsSignedIn(User))
                    {
                        <a href="/Dashboard" class="btn btn-outline-primary fw-bold px-4">Dashboard</a>
                        <form asp-action="Logout" asp-controller="Account" method="post" class="m-0">
                            <button type="submit" class="btn btn-primary fw-bold px-4 shadow-sm">Logout</button>
                        </form>
                    }
                    else
                    {
                        <a href="/Account/Login" class="btn btn-outline-primary fw-bold px-4">Login</a>
                        <a href="/Account/Register" class="btn btn-primary fw-bold px-4 shadow-sm">Register</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <!-- Hero Section -->
    <section class="hero-section">
        <div class="container text-center py-5">
            <div class="row justify-content-center">
                <div class="col-lg-8">
                    <h1 class="hero-title mb-4">Transform Your Life <span class="text-primary">Into a Game</span></h1>
                    <p class="lead text-muted mb-5">Track your goals, complete challenges, earn points, and improve your habits with a gamified productivity system.</p>
                    <div class="d-flex justify-content-center gap-3">
                        @if (SignInManager.IsSignedIn(User))
                        {
                            <a href="/Dashboard" class="btn btn-primary btn-lg px-5 py-3 shadow-lg fw-bold">Go to Dashboard</a>
                        }
                        else
                        {
                            <a href="/Account/Register" class="btn btn-primary btn-lg px-5 py-3 shadow-lg fw-bold">Start Your Quest</a>
                            <a href="/Account/Login" class="btn btn-outline-secondary btn-lg px-5 py-3 fw-bold">Login</a>
                        }
                    </div>
                </div>
            </div>
            
            <!-- Dashboard Illustration Placeholder -->
            <div class="mt-5 pt-4">
                <div class="card shadow-lg border-0 bg-white p-3 mx-auto" style="max-width: 900px; border-radius: 20px; transform: perspective(1000px) rotateX(10deg);">
                    <img src="~/images/landing-dashboard-m.png" alt="LifeQuest Dashboard Interface" class="img-fluid rounded-4 w-100" style="object-fit: cover;" />
                </div>
            </div>
        </div>
    </section>

    <!-- Features Section -->
    <section id="features" class="py-5 bg-white">
        <div class="container py-5">
            <div class="text-center mb-5">
                <h6 class="text-primary fw-bold text-uppercase">Features</h6>
                <h2 class="fw-bold fs-1">Built for Productivity</h2>
            </div>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="card h-100 feature-card p-4 rounded-4 shadow-sm">
                        <div class="feature-icon bg-primary bg-opacity-10 text-primary">
                            <i class="fas fa-trophy"></i>
                        </div>
                        <h4 class="fw-bold mb-3">Challenges</h4>
                        <p class="text-muted">Create personal challenges and stay committed to your goals with daily tracking.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 feature-card p-4 rounded-4 shadow-sm">
                        <div class="feature-icon bg-warning bg-opacity-10 text-warning">
                            <i class="fas fa-star"></i>
                        </div>
                        <h4 class="fw-bold mb-3">Points & Badges</h4>
                        <p class="text-muted">Earn points and unlock rare achievements as you progress through your daily quests.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card h-100 feature-card p-4 rounded-4 shadow-sm">
                        <div class="feature-icon bg-info bg-opacity-10 text-info">
                            <i class="fas fa-chart-line"></i>
                        </div>
                        <h4 class="fw-bold mb-3">Behavior Analytics</h4>
                        <p class="text-muted">Understand your habits and improve your decisions with detailed behavioral analytics.</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- How It Works Section -->
    <section id="challenges" class="py-5 bg-light">
        <div class="container py-5 text-center">
            <h2 class="fw-bold fs-1 mb-5">How It Works</h2>
            <div class="row">
                <div class="col-md-4 mb-4">
                    <div class="step-number">1</div>
                    <i class="fas fa-plus-circle fa-3x text-primary mb-3"></i>
                    <h5 class="fw-bold">Create a Challenge</h5>
                    <p class="text-muted small px-3">Define your goal, duration and difficulty level to start your journey.</p>
                </div>
                <div class="col-md-4 mb-4">
                    <div class="step-number">2</div>
                    <i class="fas fa-check-circle fa-3x text-success mb-3"></i>
                    <h5 class="fw-bold">Check-in Daily</h5>
                    <p class="text-muted small px-3">Log your progress every day to maintain your streak and earn points.</p>
                </div>
                <div class="col-md-4 mb-4">
                    <div class="step-number">3</div>
                    <i class="fas fa-percentage fa-3x text-info mb-3"></i>
                    <h5 class="fw-bold">Track Your Progress</h5>
                    <p class="text-muted small px-3">Monitor your improvement through interactive charts and insights.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Call To Action Section -->
    <section class="cta-section text-center">
        <div class="container py-4">
            <h2 class="fw-bold fs-1 mb-4">Ready to start improving your life?</h2>
            <div class="d-flex justify-content-center gap-3">
                @if (SignInManager.IsSignedIn(User))
                {
                    <a href="/Dashboard" class="btn btn-light btn-lg px-5 py-3 shadow fw-bold">Return to Dashboard</a>
                }
                else
                {
                    <a href="/Account/Register" class="btn btn-light btn-lg px-5 py-3 shadow fw-bold">Create Account</a>
                    <a href="/Account/Login" class="btn btn-outline-light btn-lg px-5 py-3 fw-bold">Login</a>
                }
            </div>
        </div>
    </section>

    <!-- Footer -->
    <footer class="footer-landing">
        <div class="container">
            <div class="row mb-4">
                <div class="col-lg-4 mb-4">
                    <a class="navbar-brand fw-extrabold text-primary fs-3 d-flex align-items-center mb-3" href="#">
                        <i class="fas fa-rocket me-2"></i> Life Quest
                    </a>
                    <p class="text-muted small">Elevate your productivity through gamification. Track goals, conquer challenges, and unlock your true potential.</p>
                </div>
                <div class="col-lg-2 offset-lg-2 col-md-4 col-6 mb-4">
                    <h6 class="fw-bold mb-3">Platform</h6>
                    <ul class="list-unstyled small">
                        <li><a href="/Dashboard" class="text-muted text-decoration-none py-1 d-block">Dashboard</a></li>
                        <li><a href="/Challenges" class="text-muted text-decoration-none py-1 d-block">Challenges</a></li>
                        <li><a href="/Analytics" class="text-muted text-decoration-none py-1 d-block">Analytics</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-4 col-6 mb-4">
                    <h6 class="fw-bold mb-3">Resources</h6>
                    <ul class="list-unstyled small">
                        <li><a href="#" class="text-muted text-decoration-none py-1 d-block">Community</a></li>
                        <li><a href="#" class="text-muted text-decoration-none py-1 d-block">Guidelines</a></li>
                        <li><a href="#" class="text-muted text-decoration-none py-1 d-block">Support</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-4 col-12 mb-4">
                    <h6 class="fw-bold mb-3">Follow Us</h6>
                    <div class="d-flex gap-3">
                        <a href="#" class="text-muted fs-5"><i class="fab fa-twitter"></i></a>
                        <a href="#" class="text-muted fs-5"><i class="fab fa-github"></i></a>
                        <a href="#" class="text-muted fs-5"><i class="fab fa-discord"></i></a>
                    </div>
                </div>
            </div>
            <hr class="my-4 opacity-5">
            <div class="text-center text-muted xsmall">
                <p class="mb-0">&copy; 2026 Life Quest Productivity System. All rights reserved.</p>
            </div>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
